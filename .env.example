# ===================================
# Database Configuration
# ===================================
DB_HOST=db
DB_USER=stock_user
DB_PASS=StockPassword123!
DB_NAME=stock_management_system
DB_ROOT_PASS=RootPassword123!
DB_PORT=3306

# ===================================
# Application Configuration
# ===================================
APP_NAME=Stock Management System
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# ===================================
# PHP Configuration
# ===================================
PHP_MEMORY_LIMIT=256M
MAX_EXECUTION_TIME=300
DISPLAY_ERRORS=true
LOG_ERRORS=true

# ===================================
# Session Configuration
# ===================================
SESSION_LIFETIME=1440
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ===================================
# SSLCommerz Payment Gateway
# ===================================
SSLCOMMERZ_STORE_ID=your_store_id_here
SSLCOMMERZ_STORE_PASS=your_store_password_here
SSLCOMMERZ_SANDBOX=true

# ===================================
# Email Configuration (Future Use)
# ===================================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_password_here
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@stock.local
MAIL_FROM_NAME="Stock Management System"

# ===================================
# Cache Configuration
# ===================================
CACHE_DRIVER=file
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ===================================
# File Upload Configuration
# ===================================
MAX_UPLOAD_SIZE=10M
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf

# ===================================
# Logging Configuration
# ===================================
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ===================================
# Security Configuration
# ===================================
APP_KEY=your_app_key_here
ENCRYPT_ALGORITHM=AES-256-CBC

# ===================================
# Docker Configuration
# ===================================
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
